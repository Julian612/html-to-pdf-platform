# Required: API authentication key
API_KEY=your_secret_api_key_here

# Required for self-hosted (Proxmox/bare-metal) deployment
DEPLOYMENT_MODE=selfhosted
CHROME_PATH=/usr/bin/chromium

# Admin panel
ADMIN_CONFIG_PATH=/opt/html-to-pdf/admin.json
ADMIN_JWT_SECRET=change-me-to-a-random-64-char-secret

# Optional: Override default rate limits
# RATE_LIMIT_REQUESTS=100
# RATE_LIMIT_WINDOW_MS=3600000

# Optional: Override max file size (in bytes)
# MAX_FILE_SIZE=10485760  # 10MB

# Server port (default: 3000)
# PORT=3000
